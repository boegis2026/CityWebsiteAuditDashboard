@model CityWebsiteAuditDashboard.Models.WebsiteScan

@{
    ViewData["Title"] = "Scan Website";
}

<h1>Scan Website</h1>

<p class="text-muted">
    Enter a complete website address, including https://
</p>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" id="scanForm">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Url"
                       class="form-label"></label>

                <input asp-for="Url"
                       class="form-control"
                       placeholder="https://www.example.com" />

                <span asp-validation-for="Url"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes"
                       class="form-label"></label>

                <textarea asp-for="Notes"
                          class="form-control"
                          rows="3"></textarea>

                <span asp-validation-for="Notes"
                      class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       id="includeWaveScan"
                       name="includeWaveScan"
                       value="true" />

                <label class="form-check-label" for="includeWaveScan">
                    Include WAVE accessibility scan
                </label>
            </div>

            <button type="submit"
                    id="scanButton"
                    class="btn btn-primary">
                Scan Website
            </button>

            <div id="scanStatus"
                 class="alert alert-info mt-3 d-none"
                 role="status"
                 aria-live="polite">
                Scanning the website. This may take a moment.
            </div>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("scanForm")
            ?.addEventListener("submit", function () {
                const form = this;
                const button = document.getElementById("scanButton");
                const status = document.getElementById("scanStatus");

                if (!form.checkValidity()) {
                    return;
                }

                if (button) {
                    button.disabled = true;
                    button.textContent = "Scanning...";
                }

                status?.classList.remove("d-none");
            });
    </script>
}
