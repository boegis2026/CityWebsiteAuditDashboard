@model CityWebsiteAuditDashboard.Models.WebsiteScan

@{
    ViewData["Title"] = "Scan Website";
}

<h1>Scan Website</h1>

<p class="text-muted">
    Enter a complete website address, including https://
</p>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Url"
                       class="form-label"></label>

                <input asp-for="Url"
                       class="form-control"
                       placeholder="https://www.example.com" />

                <span asp-validation-for="Url"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes"
                       class="form-label"></label>

                <textarea asp-for="Notes"
                          class="form-control"
                          rows="3"></textarea>

                <span asp-validation-for="Notes"
                      class="text-danger"></span>
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Scan Website
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
