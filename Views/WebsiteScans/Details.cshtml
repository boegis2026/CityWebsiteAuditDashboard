@model CityWebsiteAuditDashboard.Models.WebsiteScan

@{
    ViewData["Title"] = "Scan Details";

    bool isSuccessful =
        Model.HttpStatusCode >= 200 &&
        Model.HttpStatusCode < 400;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Scan Details</h1>
        <p class="text-muted mb-0">
            Full results for this website audit.
        </p>
    </div>

    <a asp-action="Index" class="btn btn-secondary">
        Back to Dashboard
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>@Model.Url</strong>

        @if (isSuccessful)
        {
            <span class="badge bg-success">
                HTTP @Model.HttpStatusCode
            </span>
        }
        else if (Model.HttpStatusCode.HasValue)
        {
            <span class="badge bg-danger">
                HTTP @Model.HttpStatusCode
            </span>
        }
        else
        {
            <span class="badge bg-secondary">
                Failed
            </span>
        }
    </div>

    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <h6 class="text-muted">Website URL</h6>
                <p>
                    <a href="@Model.Url"
                       target="_blank"
                       rel="noopener noreferrer">
                        @Model.Url
                    </a>
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">Date Scanned</h6>
                <p>
                    @Model.DateScanned
                    .ToLocalTime()
                    .ToString("MMMM d, yyyy h:mm:ss tt")
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">HTTP Status</h6>
                <p>
                    @(Model.HttpStatusCode?.ToString() ?? "Unavailable")
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">Response Time</h6>
                <p>
                    @(Model.ResponseTimeMilliseconds?.ToString() ?? "Unavailable") ms
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">Server Header</h6>
                <p>
                    @(Model.ServerHeader ?? "Not provided")
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">X-Powered-By</h6>
                <p>
                    @(Model.XPoweredByHeader ?? "Not provided")
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">IPv4 Address</h6>
                <p>
                    @(Model.IPv4Address ?? "Unavailable")
                </p>
            </div>

            <div class="col-md-6">
                <h6 class="text-muted">Notes</h6>
                <p>
                    @(Model.Notes ?? "No notes")
                </p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ScanError))
        {
            <div class="alert alert-danger mt-3">
                <strong>Scan Error:</strong>
                @Model.ScanError
            </div>
        }
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header">
            <h2 class="h5 mb-0">Accessibility Results</h2>
        </div>

        <div class="card-body">
            @if (Model.WaveScanSucceeded == true)
            {
                <div class="row g-3">
                    <div class="col-md-6 col-lg">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Errors</div>
                            <div class="fs-4 fw-semibold">
                                @(Model.WaveErrors ?? 0)
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Contrast Errors</div>
                            <div class="fs-4 fw-semibold">
                                @(Model.WaveContrastErrors ?? 0)
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Alerts</div>
                            <div class="fs-4 fw-semibold">
                                @(Model.WaveAlerts ?? 0)
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">Features</div>
                            <div class="fs-4 fw-semibold">
                                @(Model.WaveFeatures ?? 0)
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">ARIA</div>
                            <div class="fs-4 fw-semibold">
                                @(Model.WaveAria ?? 0)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-muted">
                    <strong>Last scanned:</strong>
                    @(Model.WaveScannedAt?.ToString("g") ?? "Unknown")
                </div>
            }
            else if (Model.WaveScanSucceeded == false)
            {
                <div class="alert alert-warning mb-0" role="alert">
                    <strong>Accessibility scan unsuccessful.</strong>

                    <div class="mt-1">
                        @(string.IsNullOrWhiteSpace(Model.WaveErrorMessage)
                            ? "The WAVE accessibility scan could not be completed."
                            : Model.WaveErrorMessage)
                    </div>

                    @if (Model.WaveScannedAt.HasValue)
                    {
                        <div class="small mt-2">
                            Attempted on @Model.WaveScannedAt.Value.ToString("g")
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-muted">
                    This website has not been scanned with WAVE.
                </div>
            }
        </div>
    </div>

    @if (Model.WaveAccessibilityIssues.Any())
    {
        <hr class="my-4" />

        <h3 class="h6 mb-3">
            Accessibility Issue Breakdown
        </h3>

        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th scope="col">Category</th>
                        <th scope="col">Issue</th>
                        <th scope="col" class="text-end">Count</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var issue in Model.WaveAccessibilityIssues
                        .OrderBy(issue => issue.Category == "Error" ? 1
                            : issue.Category == "Contrast" ? 2
                            : issue.Category == "Alert" ? 3
                            : issue.Category == "Feature" ? 4
                            : issue.Category == "ARIA" ? 5
                            : issue.Category == "Structure" ? 6
                            : 7)
                        .ThenByDescending(issue => issue.Count)
                        .ThenBy(issue => issue.Description))
                    {
                        <tr>
                            <td>
                                @if (issue.Category == "Error")
                                {
                                    <span class="badge bg-danger">Error</span>
                                }
                                else if (issue.Category == "Contrast")
                                {
                                    <span class="badge bg-danger">
                                        Contrast
                                    </span>
                                }
                                else if (issue.Category == "Alert")
                                {
                                    <span class="badge bg-warning text-dark">
                                        Alert
                                    </span>
                                }
                                else if (issue.Category == "Feature")
                                {
                                    <span class="badge bg-success">
                                        Feature
                                    </span>
                                }
                                else if (issue.Category == "ARIA")
                                {
                                    <span class="badge bg-info text-dark">
                                        ARIA
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        @issue.Category
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="fw-semibold">
                                    @issue.Description
                                </div>

                                <div class="small text-muted">
                                    @issue.IssueCode
                                </div>
                            </td>

                            <td class="text-end fw-semibold">
                                @issue.Count
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-light border mt-4 mb-0">
            WAVE completed successfully, but no detailed issue types were returned.
        </div>
    }

    <div class="card-footer d-flex gap-2">
        <form asp-action="ScanAgain"
              asp-route-id="@Model.Id"
              method="post">
            @Html.AntiForgeryToken()

            <button type="submit"
                    class="btn btn-success">
                Scan Again
            </button>
        </form>

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-outline-primary">
            Edit Notes
        </a>

        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-outline-danger">
            Delete
        </a>
    </div>
</div>
