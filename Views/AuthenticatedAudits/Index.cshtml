@model CityWebsiteAuditDashboard.ViewModels.AuthenticatedAuditDashboardViewModel
@using CityWebsiteAuditDashboard.Services.AuthenticatedAuditing

@{
    ViewData["Title"] = "Authenticated Audit";
}

<div class="container py-4">
    <div class="d-flex flex-wrap
        justify-content-between
        align-items-start
        gap-3
        mb-4">
        <div>
            <h1 class="h2">Authenticated Accessibility Audit</h1>

            <p class="text-muted mb-0">
                Open a visible Playwright browser, log in manually, and scan each
                rendered application state without automatically advancing or
                submitting the protected workflow.
            </p>
        </div>

        <a asp-controller="AuthenticatedAudits"
           asp-action="History"
           class="btn btn-outline-secondary">
            View Audit History
        </a>
    </div>

    @*
        Validation errors can include invalid start information, a missing
        in memory browser session, or a Playwright/database failure.
    *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger"
             role="alert">
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info" role="status">
            @Model.StatusMessage
        </div>
    }

    @if (!Model.SessionIsActive)
    {
        <div class="card shadow-sm">
            <div class="card-header">
                <h2 class="h5 mb-0">Start authenticated audit</h2>
            </div>

            <div class="card-body">
                <form asp-controller="AuthenticatedAudits"
                      asp-action="Start"
                      method="post">

                    <div class="mb-3">
                        <label asp-for="StartInput.ApplicationName"
                               class="form-label">
                        </label>

                        <input asp-for="StartInput.ApplicationName"
                               class="form-control"
                               placeholder="Example: Class A Permits" />

                        <span asp-validation-for="StartInput.ApplicationName"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="StartInput.StartingUrl"
                               class="form-label">
                        </label>

                        <input asp-for="StartInput.StartingUrl"
                               class="form-control"
                               placeholder="https://example.gov/login" />

                        <span asp-validation-for="StartInput.StartingUrl"
                              class="text-danger">
                        </span>

                        <div class="form-text">
                            Enter the page where the manual authentication
                            process should begin.
                        </div>
                    </div>

                    <div class="alert alert-warning">
                        <strong>Important:</strong>
                        The browser opens on the computer running this dashboard.
                        Complete the login manually and do not enter credentials
                        into the dashboard itself.
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Start Browser Session
                    </button>

                    <div id="authenticatedAuditStartProgress"
                         class="alert alert-primary mt-3 mb-0 d-none"
                         role="status"
                         aria-live="polite">
                        <strong>Starting authenticated browser session.</strong>
                        Please wait while the Playwright-controlled Edge window opens.
                    </div>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header">
                        <h2 class="h5 mb-0">Active browser session</h2>
                    </div>

                    <div class="card-body">
                        <dl class="row mb-4">
                            <dt class="col-sm-4">Application</dt>
                            <dd class="col-sm-8">
                                @Model.ApplicationName
                            </dd>

                            <dt class="col-sm-4">Starting URL</dt>
                            <dd class="col-sm-8 text-break">
                                @Model.StartingUrl
                            </dd>

                            <dt class="col-sm-4">Accessibility engine</dt>
                            <dd class="col-sm-8">
                                @Model.AccessibilityEngine
                            </dd>

                            <dt class="col-sm-4">Started</dt>
                            <dd class="col-sm-8">
                                @if (Model.StartedAt.HasValue)
                                {
                                    @Model.StartedAt.Value.ToString(
                                        "yyyy-MM-dd HH:mm:ss 'UTC'")
                                }
                                else
                                {
                                    <span>Unknown</span>
                                }
                            </dd>
                        </dl>

                        <div class="card shadow-sm mb-4">
                            <div class="card-body">
                                <h2 class="h5 mb-2">
                                    Authenticated Batch Analysis
                                </h2>

                                <p class="text-muted mb-4">
                                    Log in once in the Playwright-controlled Edge window, then paste
                                    protected URLs below. The dashboard will visit and scan every URL
                                    automatically using the same authenticated session.
                                </p>

                                <form asp-action="ScanBatch"
                                      method="post"
                                      id="authenticatedBatchForm"
                                      data-starting-url="@Model.StartingUrl">

                                    @Html.AntiForgeryToken()

                                    <input asp-for="BatchInput.SessionId"
                                           type="hidden"
                                           value="@Model.SessionId.GetValueOrDefault()" />

                                    <div asp-validation-summary="ModelOnly"
                                         class="text-danger mb-3">
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-3">
                                            <label asp-for="BatchInput.NumberOfUrls"
                                                   class="form-label">
                                            </label>

                                            <input asp-for="BatchInput.NumberOfUrls"
                                                   id="authenticatedBatchExpectedCount"
                                                   class="form-control"
                                                   type="number"
                                                   min="1"
                                                   max="25"
                                                   placeholder="Example: 5" />

                                            <span asp-validation-for="BatchInput.NumberOfUrls"
                                                  class="text-danger">
                                            </span>
                                        </div>

                                        <div class="col-md-9">
                                            <label asp-for="BatchInput.Urls"
                                                   class="form-label">
                                            </label>

                                            <textarea asp-for="BatchInput.Urls"
                                                      class="form-control"
                                                      rows="7"
                                                      id="authenticatedBatchUrls"
                                                      placeholder="https://protected-app.example/page-1&#10;https://protected-app.example/page-2"></textarea>

                                            <span asp-validation-for="BatchInput.Urls"
                                                  class="text-danger">
                                            </span>

                                            <div id="authenticatedBatchUrlStatus"
                                                 class="alert alert-secondary py-2 mt-2 mb-0"
                                                 role="status"
                                                 aria-live="polite">
                                                No protected URLs detected yet.
                                            </div>

                                            <div id="authenticatedBatchDomainWarning"
                                                 class="alert alert-warning py-2 mt-2 mb-0 d-none"
                                                 role="status"
                                                 aria-live="polite">
                                            </div>

                                            <div class="form-text">
                                                Enter one complete HTTP or HTTPS URL per line. Blank
                                                lines are ignored. Maximum: 25 URLs.
                                            </div>
                                        </div>
                                    </div>

                                    <div class="alert alert-info mt-3 mb-3">
                                        <strong>Before running:</strong>
                                        Confirm that the Edge browser is still open and that you are
                                        already signed in to the protected application.
                                    </div>

                                    <button type="submit"
                                            class="btn btn-primary"
                                            id="authenticatedBatchButton">
                                        <span id="authenticatedBatchButtonText">
                                            Run Authenticated Batch
                                        </span>

                                        <span id="authenticatedBatchSpinner"
                                              class="spinner-border spinner-border-sm ms-2 d-none"
                                              aria-hidden="true">
                                        </span>
                                    </button>

                                    <div id="authenticatedBatchProgress"
                                         class="alert alert-primary mt-3 mb-0 d-none"
                                         role="status"
                                         aria-live="polite">
                                        <strong>Authenticated batch is running.</strong>
                                        Edge is automatically visiting and scanning each protected URL.
                                        Keep both browser windows open until the dashboard returns.
                                    </div>
                                </form>
                            </div>
                        </div>

                        @if (Model.LastBatchResult is not null)
                        {
                            int totalViolationRules =
                                Model.LastBatchResult.Items.Sum(
                                    item => item.ViolationRuleCount);

                            int totalNeedsReviewRules =
                                Model.LastBatchResult.Items.Sum(
                                    item => item.NeedsReviewRuleCount);

                            int totalAffectedElements =
                                Model.LastBatchResult.Items.Sum(
                                    item => item.AffectedElementCount);

                            int redirectedPageCount =
                                Model.LastBatchResult.Items.Count(
                                    item => item.WasRedirected);

                            var attentionItems =
                                Model.LastBatchResult.Items
                                    .Where(item =>
                                        !item.Succeeded ||
                                        item.WasRedirected)
                                    .ToList();

                            string attentionUrls =
                                string.Join(
                                    Environment.NewLine,
                                    attentionItems.Select(item => item.Url));

                            long averageDurationMilliseconds =
                                Model.LastBatchResult.Items.Count > 0
                                    ? (long)Model.LastBatchResult.Items.Average(
                                        item => item.DurationMilliseconds)
                                    : 0;

                            TimeSpan averagePageDuration =
                                TimeSpan.FromMilliseconds(
                                    averageDurationMilliseconds);

                            TimeSpan totalBatchDuration =
                                TimeSpan.FromMilliseconds(
                                    Model.LastBatchResult.DurationMilliseconds);

                            <div class="card shadow-sm mb-4">

                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-white">
                                    <div class="d-flex flex-wrap justify-content-between
                                        align-items-center gap-2">
                                        <h2 class="h5 mb-0">
                                            Latest Authenticated Batch Results
                                        </h2>

                                        <div class="d-flex gap-2">
                                            <span class="badge bg-primary">
                                                Requested:
                                                @Model.LastBatchResult.RequestedCount
                                            </span>

                                            <span class="badge bg-secondary">
                                                Total Time:
                                                @totalBatchDuration.ToString(@"m\:ss")
                                            </span>

                                            <span class="badge bg-success">
                                                Succeeded:
                                                @Model.LastBatchResult.SucceededCount
                                            </span>

                                            @if (Model.LastBatchResult.FailedCount > 0)
                                            {
                                                <span class="badge bg-danger">
                                                    Failed:
                                                    @Model.LastBatchResult.FailedCount
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <form asp-controller="AuthenticatedAudits"
                                      asp-action="LoadAttentionUrls"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    @foreach (var attentionItem in attentionItems)
                                    {
                                        <input type="hidden"
                                               name="urls"
                                               value="@attentionItem.Url" />
                                    }

                                    <button 
                                        type="submit"
                                        class="btn btn-sm btn-outline-warning">
                                        Load Attention URLs

                                        <span class="badge bg-warning text-dark ms-1">
                                            @attentionItems.Count
                                        </span>
                                    </button>
                                </form>

                                @if (attentionItems.Count > 0)
                                {
                                    <button 
                                        type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        id="authenticatedBatchAttentionFilterButton">
                                        Show Attention Only
                                    </button>

                                }

                                @if (redirectedPageCount > 0)
                                {
                                    <div class="alert alert-warning rounded-0 mb-0">
                                        <strong>Navigation review required.</strong>

                                        @redirectedPageCount
                                        requested URL(s) ended on a different page.

                                        Review the final URLs below. A redirect may be expected, but it can
                                        also indicate that the authenticated session expired or that the
                                        application returned to a sign-in page.
                                    </div>
                                }

                                <div class="card-body border-bottom">
                                    <div class="row g-3 text-center">
                                        <div class="col-6 col-lg-3">
                                            <div class="fw-semibold fs-4">
                                                @totalViolationRules
                                            </div>

                                            <div class="small text-muted">
                                                Violation Rules
                                            </div>
                                        </div>

                                        <div class="col-6 col-lg-3">
                                            <div class="fw-semibold fs-4">
                                                @totalNeedsReviewRules
                                            </div>

                                            <div class="small text-muted">
                                                Needs Review
                                            </div>
                                        </div>

                                        <div class="col-6 col-lg-3">
                                            <div class="fw-semibold fs-4">
                                                @totalAffectedElements
                                            </div>

                                            <div class="small text-muted">
                                                Affected Elements
                                            </div>
                                        </div>

                                        <div class="col-6 col-lg-3">
                                            <div class="fw-semibold fs-4">
                                                @averagePageDuration.ToString(@"m\:ss\.fff")
                                            </div>

                                            <div class="small text-muted">
                                                Average Page Time
                                            </div>
                            </div>
                        </div>
                    </div>

                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle mb-0">
                                            <thead class="table-light">
                                                <tr>
                                                    <th scope="col">URL</th>
                                                    <th scope="col">Navigation</th>
                                                    <th scope="col">Result</th>
                                                    <th scope="col">Scan Time</th>
                                                    <th scope="col">Step</th>
                                                    <th scope="col">Violations</th>
                                                    <th scope="col">Needs Review</th>
                                                    <th scope="col">Affected Elements</th>
                                                </tr>
                                            </thead>

                                            <tbody id="authenticatedBatchResultsBody">
                                                @foreach (
                                                    AuthenticatedAuditBatchItemResult item
                                                    in Model.LastBatchResult.Items)
                                                {
                                                    <tr data-attention="@(
                                                        (!item.Succeeded || item.WasRedirected)
                                                            .ToString()
                                                            .ToLowerInvariant())">
                                                        <td class="text-break">
                                                            <a href="@item.Url"
                                                               target="_blank"
                                                               rel="noopener noreferrer">
                                                                @item.Url
                                                            </a>

                                                            @if (!string.IsNullOrWhiteSpace(
                                                                item.ErrorMessage))
                                                            {
                                                                <div class="small text-danger mt-1">
                                                                    @item.ErrorMessage
                                                                </div>
                                                            }
                                                        </td>

                                                        <td>
                                                            @if (item.Succeeded)
                                                            {
                                                                <span class="badge bg-success">
                                                                    Saved
                                                                </span>
                                                            }
                                                            @if (redirectedPageCount > 0)
                                                            {
                                                                <span class="badge bg-warning text-dark">
                                                                    Redirected:
                                                                    @redirectedPageCount
                                                                </span>
                                                             }
                                                            else
                                                            {
                                                                <span class="badge bg-danger">
                                                                    Failed
                                                                </span>
                                                            }
                                                        </td>

                                                        <td>
                                                            @{
                                                                TimeSpan itemDuration =
                                                                    TimeSpan.FromMilliseconds(
                                                                        item.DurationMilliseconds);
                                                            }

                                                            @itemDuration.ToString(@"m\:ss\.fff")
                                                        </td>

                                                        <td>
                                                            @if (item.StepNumber.HasValue)
                                                            {
                                                                <span>
                                                                    @item.StepNumber
                                                                </span>

                                                                @if (!string.IsNullOrWhiteSpace(
                                                                    item.StepName))
                                                                {
                                                                    <div class="small text-muted">
                                                                        @item.StepName
                                                                    </div>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>

                                                        <td>
                                                            @if (item.WasRedirected)
                                                            {
                                                                <span class="badge bg-warning text-dark">
                                                                    Redirected
                                                                </span>

                                                                @if (!string.IsNullOrWhiteSpace(item.FinalUrl))
                                                                {
                                                                    <div class="small text-muted text-break mt-1">
                                                                        Final URL:
                                                                        <a href="@item.FinalUrl"
                                                                           target="_blank"
                                                                           rel="noopener noreferrer">
                                                                           @item.FinalUrl
                                                                        </a>
                                                                    </div>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-success">
                                                                    Requested Page
                                                                </span>
                                                            }
                                                        </td>

                                                        <td>
                                                            @item.ViolationRuleCount
                                                        </td>

                                                        <td>
                                                            @item.NeedsReviewRuleCount
                                                        </td>

                                                        <td>
                                                            @item.AffectedElementCount
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="card-footer bg-white text-muted small">
                                    Full rule-level findings are available in Authenticated Audit
                                    History after the session is completed.
                                </div>
                            </div>
                        }
                            </div>
                        }

                        <div class="alert alert-secondary">
                            <ol class="mb-0">
                                <li>
                                    Use the Playwright-controlled Edge browser to sign in.
                                </li>
                                <li>
                                    For one page, navigate to the desired state and select
                                    <strong>Scan Current Step</strong>.
                                </li>
                                <li>
                                    For multiple known pages, paste their URLs into
                                    <strong>Authenticated Batch Analysis</strong>.
                                </li>
                                <li>
                                    Select <strong>Run Authenticated Batch</strong>.
                                    Edge will visit and scan each URL automatically.
                                </li>
                                <li>
                                    Select <strong>Complete and Close Browser</strong>
                                    when the audit is finished.
                                </li>
                            </ol>
                        </div>

                        @*
                            These hidden fields preserve the information needed
                            to redisplay the session after the Scan POST request.

                            The live Playwright browser objects remain only in
                            AuthenticatedAuditService.
                        *@
                        <form asp-controller="AuthenticatedAudits"
                              asp-action="Scan"
                              method="post"
                              id="authenticatedAuditScanForm">

                            <input type="hidden"
                                   name="SessionId"
                                   value="@Model.SessionId" />

                            <input type="hidden"
                                   name="ApplicationName"
                                   value="@Model.ApplicationName" />

                            <input type="hidden"
                                   name="StartingUrl"
                                   value="@Model.StartingUrl" />

                            <input type="hidden"
                                   name="AccessibilityEngine"
                                   value="@Model.AccessibilityEngine" />

                            <input type="hidden"
                                   name="StartedAt"
                                   value="@Model.StartedAt?.ToString("O")" />

                            <button type="submit"
                                    class="btn btn-primary"
                                    id="authenticatedAuditScanButton">
                                <span id="authenticatedAuditScanButtonText">
                                    Scan Current Step
                                </span>

                                <span id="authenticatedAuditScanSpinner"
                                      class="spinner-border spinner-border-sm ms-2 d-none"
                                      aria-hidden="true">
                                </span>
                            </button>

                            <div id="authenticatedAuditScanProgress"
                                 class="alert alert-primary mt-3 mb-0 d-none"
                                 role="status"
                                 aria-live="polite">
                                <strong>Scanning the current protected page.</strong>
                                Keep the Playwright-controlled Edge window open while axe analyzes and
                                saves the rendered page.
                            </div>
                        </form>

                        @* Updated by JavaScript while the authenticated scan is running. *@
                        <div id="authenticatedAuditProgressPanel"
                             class="card border-primary mt-3 d-none"
                             aria-live="polite"
                             aria-atomic="true">

                            <div class="card-body">
                                <h5 class="card-title">
                                    Authenticated Scan Progress
                                </h5>

                                <div class="mb-2">
                                    <strong>Current page:</strong>
                                    <span id="authenticatedAuditCurrentUrl">
                                        Preparing scan...
                                    </span>
                                </div>

                                <div class="mb-2">
                                    <strong>Saved step:</strong>
                                    <span id="authenticatedAuditCurrentStep">
                                        —
                                    </span>
                                </div>

                                <div class="mb-2">
                                    <strong>Current stage:</strong>
                                    <span id="authenticatedAuditCurrentStage">
                                        Opening page
                                    </span>
                                </div>

                                <div class="progress"
                                     role="progressbar"
                                     aria-label="Current page scan stage"
                                     aria-valuemin="0"
                                     aria-valuemax="100">

                                    <div id="authenticatedAuditProgressBar"
                                         class="progress-bar progress-bar-striped progress-bar-animated"
                                         style="width: 0%;"
                                         aria-valuenow="0">
                                        0%
                                    </div>
                                </div>

                                <div class="form-text mt-2">
                                    This percentage represents the current scan stage,
                                    not the percentage of the page DOM analyzed.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card border-danger shadow-sm h-100">
                    <div class="card-header">
                        <h2 class="h5 mb-0">Complete session</h2>
                    </div>

                    <div class="card-body">
                        <p>
                            Completing the session closes the Playwright browser
                            and marks the audit run as completed in SQL Server.
                        </p>

                        <p class="text-muted">
                            It does not click Submit, Pay, Certify, Finish,
                            Finalize, or any other application control.
                        </p>

                        <form asp-controller="AuthenticatedAudits"
                              asp-action="Stop"
                              method="post"
                              id="authenticatedAuditStopForm">

                            <input type="hidden"
                                   name="SessionId"
                                   value="@Model.SessionId" />

                            <input type="hidden"
                                   name="ApplicationName"
                                   value="@Model.ApplicationName" />

                            <input type="hidden"
                                   name="StartingUrl"
                                   value="@Model.StartingUrl" />

                            <input type="hidden"
                                   name="AccessibilityEngine"
                                   value="@Model.AccessibilityEngine" />

                            <input type="hidden"
                                   name="StartedAt"
                                   value="@Model.StartedAt?.ToString("O")" />

                            <div class="form-check mb-3">
                                <input class="form-check-input"
                                       type="checkbox"
                                       name="MarkLastStepAsFinal"
                                       value="true"
                                       checked
                                       id="markLastStepAsFinal" />

                                @*
                                    An unchecked checkbox sends no value.

                                    This hidden input ensures false is posted
                                    when the user clears the checkbox.
                                *@
                                <input type="hidden"
                                       name="MarkLastStepAsFinal"
                                       value="false" />

                                <label class="form-check-label"
                                       for="markLastStepAsFinal">
                                    Mark the last scanned state as final
                                </label>
                            </div>

                            <button type="submit" class="btn btn-danger">
                                Complete and Close Browser
                            </button>

                            <div id="authenticatedAuditStopProgress"
                                 class="alert alert-secondary mt-3 mb-0 d-none"
                                 role="status"
                                 aria-live="polite">
                                <strong>Completing the authenticated audit.</strong>
                                Please wait while the audit run is finalized and the
                                Playwright-controlled Edge browser closes.
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.LastStepResult is not null)
        {
            AuthenticatedAuditStepResult step = Model.LastStepResult;

            <div class="card shadow-sm mt-4">
                <div class="card-header d-flex
                            justify-content-between
                            align-items-center">

                    <h2 class="h5 mb-0">
                        Last scanned state: Step @step.StepNumber
                    </h2>

                    @if (step.ScanSucceeded)
                    {
                        <span class="badge bg-success">
                            Scan succeeded
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Scan failed
                        </span>
                    }
                </div>

                <div class="card-body">
                    <dl class="row">
                        <dt class="col-md-3">Step name</dt>
                        <dd class="col-md-9">
                            @step.StepName
                        </dd>

                        <dt class="col-md-3">Page title</dt>
                        <dd class="col-md-9">
                            @(step.PageTitle ?? "Not detected")
                        </dd>

                        <dt class="col-md-3">Main heading</dt>
                        <dd class="col-md-9">
                            @(step.Heading ?? "Not detected")
                        </dd>

                        <dt class="col-md-3">Current URL</dt>
                        <dd class="col-md-9 text-break">
                            @step.Url
                        </dd>

                        <dt class="col-md-3">DOM fingerprint</dt>
                        <dd class="col-md-9">
                            <code class="text-break">
                                @(step.DomFingerprint ?? "Not generated")
                            </code>
                        </dd>
                    </dl>

                    <div class="row g-3 mt-1">
                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.VisibleFormCount
                                </div>

                                <div class="small text-muted">
                                    Visible forms
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.VisibleFieldCount
                                </div>

                                <div class="small text-muted">
                                    Visible fields
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.VisibleButtonCount
                                </div>

                                <div class="small text-muted">
                                    Visible buttons
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.ViolationRuleCount
                                </div>

                                <div class="small text-muted">
                                    Violation rules
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.AffectedElementCount
                                </div>

                                <div class="small text-muted">
                                    Affected elements
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.NeedsReviewRuleCount
                                </div>

                                <div class="small text-muted">
                                    Needs review
                                </div>
                            </div>
                        </div>

                        <div class="col-6 col-md-4 col-xl-2">
                            <div class="border rounded p-3 text-center h-100">
                                <div class="fs-4 fw-semibold">
                                    @step.PassedRuleCount
                                </div>

                                <div class="small text-muted">
                                    Passed rules
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(step.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-4 mb-0">
                            <strong>Scan error:</strong>
                            @step.ErrorMessage
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form =
                document.getElementById("authenticatedBatchForm");

            const button =
                document.getElementById("authenticatedBatchButton");

            const buttonText =
                document.getElementById(
                    "authenticatedBatchButtonText");

            const spinner =
                document.getElementById(
                    "authenticatedBatchSpinner");

            const progress =
                document.getElementById(
                    "authenticatedBatchProgress");

            const urlsTextarea =
                document.getElementById(
                    "authenticatedBatchUrls");

            const expectedCountInput =
                document.getElementById(
                    "authenticatedBatchExpectedCount");

            if (
                urlsTextarea !== null &&
                expectedCountInput !== null
            ) {
            
            if (form === null || button === null) {
                return;
            }

            let submitted = false;

            form.addEventListener("submit", function (event) {
                if (submitted) {
                    event.preventDefault();
                    return;
                }

                submitted = true;

                if (buttonText !== null) {
                    buttonText.textContent =
                        "Scanning Protected URLs";
                }

                if (spinner !== null) {
                    spinner.classList.remove("d-none");
                }

                if (progress !== null) {
                    progress.classList.remove("d-none");
                }

                window.setTimeout(function () {
                    button.disabled = true;
                }, 0);
            });

        const expectedCountInput =
            document.getElementById(
                "authenticatedBatchExpectedCount");

        const urlsTextarea =
            document.getElementById(
                "authenticatedBatchUrls");

        const urlStatus =
            document.getElementById(
                "authenticatedBatchUrlStatus");

        const batchForm =
            document.getElementById(
                "authenticatedBatchForm");

        const domainWarning =
            document.getElementById(
                "authenticatedBatchDomainWarning");

        function updateAuthenticatedBatchDomainWarning(urls) {
            if (
                batchForm === null ||
                domainWarning === null
            ) {
                return;
            }

            domainWarning.classList.add("d-none");
            domainWarning.textContent = "";

            const startingUrlValue =
                batchForm.dataset.startingUrl;

            if (
                !startingUrlValue ||
                urls.length === 0
            ) {
                return;
            }

            let startingHost;

            try {
                startingHost =
                    new URL(startingUrlValue).hostname.toLowerCase();
            } catch {
                return;
            }

            const differentHosts = new Set();

            urls.forEach(function (url) {
                try {
                    const parsedUrl = new URL(url);
                    const currentHost =
                        parsedUrl.hostname.toLowerCase();

                    if (currentHost !== startingHost) {
                        differentHosts.add(currentHost);
                    }
                } catch {
                    /*
                     * Invalid URLs are already reported by the primary
                     * live-validation message.
                     */
                }
            });

            if (differentHosts.size === 0) {
                return;
            }

            domainWarning.textContent =
                "Authentication warning: the batch contains URL(s) from a " +
                "different domain than the starting application: " +
                Array.from(differentHosts).join(", ") +
                ". Those pages may require a separate login session.";

            domainWarning.classList.remove("d-none");
        }

        function updateAuthenticatedBatchStatus() {
            if (
                expectedCountInput === null ||
                urlsTextarea === null ||
                urlStatus === null
            ) {
                return;
            }

            const urls = urlsTextarea.value
                .split(/\r?\n/)
                .map(function (url) {
                    return url.trim();
                })
                .filter(function (url) {
                    return url.length > 0;
                });

            updateAuthenticatedBatchDomainWarning(urls);

            const expectedCount =
                Number.parseInt(expectedCountInput.value, 10);

            const invalidLineNumbers = [];
            const duplicateLineNumbers = [];
            const previouslySeenUrls = new Set();

            urls.forEach(function (url, index) {
                let validUrl = false;

                try {
                    const parsedUrl = new URL(url);

                    validUrl =
                        parsedUrl.protocol === "http:" ||
                        parsedUrl.protocol === "https:";
                } catch {
                    validUrl = false;
                }

                if (!validUrl) {
                    invalidLineNumbers.push(index + 1);
                }

                const duplicateKey = url.toLowerCase();

                if (previouslySeenUrls.has(duplicateKey)) {
                    duplicateLineNumbers.push(index + 1);
                } else {
                    previouslySeenUrls.add(duplicateKey);
                }

                const attentionFilterButton =
                    document.getElementById(
                        "authenticatedBatchAttentionFilterButton");

                const batchResultRows =
                    document.querySelectorAll(
                        "#authenticatedBatchResultsBody tr[data-attention]");

                if (
                    attentionFilterButton !== null &&
                    batchResultRows.length > 0
                ) {
                    let showingAttentionOnly = false;

                    attentionFilterButton.addEventListener(
                        "click",
                        function () {
                            showingAttentionOnly =
                                !showingAttentionOnly;

                            batchResultRows.forEach(function (row) {
                                const requiresAttention =
                                    row.dataset.attention === "true";

                                row.classList.toggle(
                                    "d-none",
                                    showingAttentionOnly &&
                                    !requiresAttention);
                            });

                            if (showingAttentionOnly) {
                                attentionFilterButton.textContent =
                                    "Show All Results";

                                attentionFilterButton.classList.remove(
                                    "btn-outline-secondary");

                                attentionFilterButton.classList.add(
                                    "btn-secondary");
                            } else {
                                attentionFilterButton.textContent =
                                    "Show Attention Only";

                                attentionFilterButton.classList.remove(
                                    "btn-secondary");

                                attentionFilterButton.classList.add(
                                    "btn-outline-secondary");
                            }
                        });
                }

            });

            urlStatus.classList.remove(
                "alert-secondary",
                "alert-info",
                "alert-success",
                "alert-warning",
                "alert-danger"
            );

            if (urls.length === 0) {
                urlStatus.classList.add("alert-secondary");
                urlStatus.textContent =
                    "No protected URLs detected yet.";

                return;
            }

            if (invalidLineNumbers.length > 0) {
                urlStatus.classList.add("alert-danger");
                urlStatus.textContent =
                    urls.length +
                    " non-empty URL(s) detected. Invalid URL line(s): " +
                    invalidLineNumbers.join(", ") +
                    ".";

                return;
            }

            if (
                Number.isInteger(expectedCount) &&
                expectedCount !== urls.length
            ) {
                urlStatus.classList.add("alert-warning");
                urlStatus.textContent =
                    urls.length +
                    " non-empty URL(s) detected, but Number of URLs is " +
                    expectedCount +
                    ".";

                return;
            }

            if (duplicateLineNumbers.length > 0) {
                urlStatus.classList.add("alert-warning");
                urlStatus.textContent =
                    urls.length +
                    " valid URL(s) detected. Duplicate URL line(s): " +
                    duplicateLineNumbers.join(", ") +
                    ".";

                return;
            }

            if (!Number.isInteger(expectedCount)) {
                urlStatus.classList.add("alert-info");
                urlStatus.textContent =
                    urls.length +
                    " valid URL(s) detected. Enter the same number above.";

                return;
            }

            urlStatus.classList.add("alert-success");
            urlStatus.textContent =
                urls.length +
                " valid URL(s) detected. The batch is ready to run.";
        }

        if (
            expectedCountInput !== null &&
            urlsTextarea !== null
        ) {
            expectedCountInput.addEventListener(
                "input",
                updateAuthenticatedBatchStatus);

            urlsTextarea.addEventListener(
                "input",
                updateAuthenticatedBatchStatus);

            updateAuthenticatedBatchStatus();
        }

        document.addEventListener("DOMContentLoaded", () => {
            const scanForm =
                document.getElementById(
                    "authenticatedAuditScanForm");

            if (!scanForm) {
                return;
            }

            const progressPanel =
                document.getElementById(
                    "authenticatedAuditProgressPanel");

            const currentUrlElement =
                document.getElementById(
                    "authenticatedAuditCurrentUrl");

            const currentStepElement =
                document.getElementById(
                    "authenticatedAuditCurrentStep");

            const currentStageElement =
                document.getElementById(
                    "authenticatedAuditCurrentStage");

            const progressBar =
                document.getElementById(
                    "authenticatedAuditProgressBar");

            let progressTimer = null;

            function updateAuthenticatedAuditProgress(progress) {
                const stagePercent =
                    Math.max(
                        0,
                        Math.min(
                            Number(progress.stagePercent) || 0,
                            100));

                currentUrlElement.textContent =
                    progress.currentUrl ||
                    "Preparing page...";

                currentStepElement.textContent =
                    progress.currentPageNumber > 0
                        ? progress.currentPageNumber
                        : "—";

                currentStageElement.textContent =
                    progress.stage ||
                    "Preparing scan";

                progressBar.style.width =
                    `${stagePercent}%`;

                progressBar.textContent =
                    `${stagePercent}%`;

                progressBar.setAttribute(
                    "aria-valuenow",
                    stagePercent);
            }

            async function loadAuthenticatedAuditProgress(
                sessionId) {
                try {
                    const progressUrl =
                        "@Url.Action("Progress", "AuthenticatedAudits")"
                        + `?sessionId=${encodeURIComponent(sessionId)}`;

                    const response =
                        await fetch(
                            progressUrl,
                            {
                                cache: "no-store",
                                credentials: "same-origin"
                            });

                    if (!response.ok) {
                        return;
                    }

                    const progress =
                        await response.json();

                    updateAuthenticatedAuditProgress(
                        progress);
                }
                catch {
                    /*
                     * A temporary polling error should not stop
                     * the authenticated audit already running.
                     */
                }
            }

            scanForm.addEventListener(
                "submit",
                async event => {
                    event.preventDefault();

                    const sessionInput =
                        scanForm.querySelector(
                            '[name="sessionId"]');

                    const sessionId =
                        sessionInput?.value;

                    if (!sessionId) {
                        scanForm.submit();
                        return;
                    }

                    progressPanel.classList.remove(
                        "d-none");

                    updateAuthenticatedAuditProgress({
                        stage: "Opening page",
                        stagePercent: 10,
                        currentUrl: null,
                        currentPageNumber: 0
                    });

                    const submitButton =
                        scanForm.querySelector(
                            'button[type="submit"], input[type="submit"]');

                    if (submitButton) {
                        submitButton.disabled = true;
                    }

                    progressTimer =
                        window.setInterval(
                            () =>
                                loadAuthenticatedAuditProgress(
                                    sessionId),
                            100);
                    await loadAuthenticatedAuditProgress(sessionId);

                    try {
                        const response =
                            await fetch(
                                scanForm.action,
                                {
                                    method: "POST",
                                    body: new FormData(scanForm),
                                    credentials: "same-origin"
                                });

                        window.clearInterval(
                            progressTimer);

                        await loadAuthenticatedAuditProgress(
                            sessionId);

                        /*
                         * Preserve the controller's existing
                         * Post/Redirect/Get workflow.
                         */
                        window.location.href =
                            response.url ||
                            "@Url.Action("Index", "AuthenticatedAudits")";
                    }
                    catch {
                        window.clearInterval(
                            progressTimer);

                        if (submitButton) {
                            submitButton.disabled = false;
                        }

                        currentStageElement.textContent =
                            "The scan request could not be completed.";

                        progressBar.classList.remove(
                            "progress-bar-animated");
                    }
                });

        });
    </script>
}
