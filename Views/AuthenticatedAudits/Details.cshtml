@model CityWebsiteAuditDashboard.ViewModels.AuthenticatedAuditDetailsViewModel

@{
    ViewData["Title"] = $"Authenticated Audit Run #{Model.Id}";

    string statusBadgeClass =
        Model.Status switch
            {
            "Completed" => "bg-success",
            "Running" => "bg-primary",
            "Failed" => "bg-danger",
            "Cancelled" => "bg-warning text-dark",
            "Interrupted" => "bg-warning text-dark",
            _ => "bg-secondary"
            };
}

<div class="container py-4">
    <div class="d-flex flex-wrap
        justify-content-between
        align-items-start
        gap-3
        mb-4">
        <div>
            <div class="d-flex flex-wrap
                align-items-center
                gap-2
                mb-1">
                <h1 class="h2 mb-0">
                    Authenticated Audit Run #@Model.Id
                </h1>

                <span class="badge @statusBadgeClass">
                    @Model.Status
                </span>
            </div>

            <p class="text-muted mb-0">
                Review every rendered application state scanned during this
                authenticated browser session.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="AuthenticatedAudits"
               asp-action="History"
               class="btn btn-outline-secondary">
                Back to History
            </a>

            <a asp-controller="AuthenticatedAudits"
               asp-action="Index"
               class="btn btn-primary">
                Start New Audit
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <strong>Run error:</strong>
            @Model.ErrorMessage
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <h2 class="h5 mb-0">Run information</h2>
        </div>

        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-md-3">Application</dt>
                <dd class="col-md-9">
                    @Model.ApplicationName
                </dd>

                <dt class="col-md-3">Starting URL</dt>
                <dd class="col-md-9 text-break">
                    @Model.StartingUrl
                </dd>

                <dt class="col-md-3">Accessibility engine</dt>
                <dd class="col-md-9">
                    @Model.AccessibilityEngine
                </dd>

                <dt class="col-md-3">Started</dt>
                <dd class="col-md-9">
                    @Model.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")
                    <span class="text-muted">UTC</span>
                </dd>

                <dt class="col-md-3">Completed</dt>
                <dd class="col-md-9">
                    @if (Model.CompletedAt.HasValue)
                    {
                        @Model.CompletedAt.Value.ToString(
                            "yyyy-MM-dd HH:mm:ss")

                        <span class="text-muted">UTC</span>
                    }
                    else
                    {
                        <span class="text-muted">
                            Not completed
                        </span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Total steps
                    </div>

                    <div class="fs-3 fw-semibold">
                        @Model.Steps.Count
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Successful steps
                    </div>

                    <div class="fs-3 fw-semibold">
                        @Model.SuccessfulStepCount
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Violation rules
                    </div>

                    <div class="fs-3 fw-semibold">
                        @Model.TotalViolationRuleCount
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">
                        Affected elements
                    </div>

                    <div class="fs-3 fw-semibold">
                        @Model.TotalAffectedElementCount
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Steps.Count == 0)
    {
        <div class="alert alert-info">
            No rendered states were scanned during this audit run.
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var step in Model.Steps)
            {
                string stepBorderClass =
                    step.ScanSucceeded
                        ? "border-success"
                        : "border-danger";

                <div class="card shadow-sm @stepBorderClass">
                    <div class="card-header d-flex
                        flex-wrap
                        justify-content-between
                        align-items-center
                        gap-2">
                        <div class="d-flex flex-wrap
                            align-items-center
                            gap-2">
                            <h2 class="h5 mb-0">
                                Step @step.StepNumber:
                                @step.StepName
                            </h2>

                            @if (step.WasFinalStep)
                            {
                                <span class="badge bg-dark">
                                    Final scanned state
                                </span>
                            }
                        </div>

                        @if (step.ScanSucceeded)
                        {
                            <span class="badge bg-success">
                                Scan succeeded
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Scan failed
                            </span>
                        }
                    </div>

                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-md-3">Page title</dt>
                            <dd class="col-md-9">
                                @(step.PageTitle ?? "Not detected")
                            </dd>

                            <dt class="col-md-3">Main heading</dt>
                            <dd class="col-md-9">
                                @(step.Heading ?? "Not detected")
                            </dd>

                            <dt class="col-md-3">Current URL</dt>
                            <dd class="col-md-9 text-break">
                                @step.Url
                            </dd>

                            <dt class="col-md-3">Scanned</dt>
                            <dd class="col-md-9">
                                @step.ScannedAt.ToString(
                                    "yyyy-MM-dd HH:mm:ss")

                                <span class="text-muted">UTC</span>
                            </dd>

                            <dt class="col-md-3">DOM fingerprint</dt>
                            <dd class="col-md-9">
                                @*
                                    The fingerprint identifies a rendered state
                                    without storing entered form values.
                                *@
                                <code class="text-break">
                                    @(step.DomFingerprint ?? "Not generated")
                                </code>
                            </dd>
                        </dl>

                        <div class="row g-3 mt-1">
                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.VisibleFormCount
                                    </div>

                                    <div class="small text-muted">
                                        Visible forms
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.VisibleFieldCount
                                    </div>

                                    <div class="small text-muted">
                                        Visible fields
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.VisibleButtonCount
                                    </div>

                                    <div class="small text-muted">
                                        Visible buttons
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.ViolationRuleCount
                                    </div>

                                    <div class="small text-muted">
                                        Violation rules
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.AffectedElementCount
                                    </div>

                                    <div class="small text-muted">
                                        Affected elements
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.NeedsReviewRuleCount
                                    </div>

                                    <div class="small text-muted">
                                        Needs review
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-xl">
                                <div class="border rounded
                                    p-3
                                    text-center
                                    h-100">
                                    <div class="fs-4 fw-semibold">
                                        @step.PassedRuleCount
                                    </div>

                                    <div class="small text-muted">
                                        Passed rules
                                    </div>
                                </div>
                            </div>
                        </div>

                        @*
    Only violations and needs-review rules are saved individually.
    Passed rules remain represented by the summary count above.
*@
                        @if (step.Findings.Count == 0)
                        {
                            <div class="alert alert-secondary mt-4 mb-0">
                                No rule-level violations or needs-review findings were saved
                                for this rendered state.

                                @if (step.ScanSucceeded &&
                                     (step.ViolationRuleCount > 0 ||
                                      step.NeedsReviewRuleCount > 0))
                                {
                                    <div class="small mt-2">
                                        This may be an older scan created before individual
                                        finding storage was added.
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            var violationFindings = step.Findings
                                .Where(finding =>
                                    finding.FindingType == "Violation")
                                .ToList();

                            var needsReviewFindings = step.Findings
                                .Where(finding =>
                                    finding.FindingType == "NeedsReview")
                                .ToList();

                            <div class="mt-4">
                                <h3 class="h6">
                                    Accessibility findings
                                </h3>

                                <p class="small text-muted">
                                    These records contain rule-level information only.
                                    Element HTML and entered form values are not stored.
                                </p>

                                @if (violationFindings.Count > 0)
                                {
                                    <div class="mb-4">
                                        <h4 class="h6 text-danger">
                                            Violations (@violationFindings.Count)
                                        </h4>

                                        <div class="d-flex flex-column gap-3">
                                            @foreach (var finding in violationFindings)
                                            {
                                                string impactBadgeClass =
                                                    finding.Impact?.ToLowerInvariant() switch
                                                    {
                                                        "critical" => "bg-danger",
                                                        "serious" => "bg-danger",
                                                        "moderate" => "bg-warning text-dark",
                                                        "minor" => "bg-info text-dark",
                                                        _ => "bg-secondary"
                                                    };

                                                <div class="border border-danger
                                                    rounded
                                                    p-3">
                                                    <div class="d-flex flex-wrap
                                                        justify-content-between
                                                        align-items-start
                                                        gap-2">
                                                        <div>
                                                            <div class="fw-semibold">
                                                                @finding.RuleId
                                                            </div>

                                                            @if (!string.IsNullOrWhiteSpace(
                                                                finding.Help))
                                                            {
                                                                <div>
                                                                    @finding.Help
                                                                </div>
                                                            }
                                                        </div>

                                                        <div class="d-flex flex-wrap gap-2">
                                                            <span class="badge @impactBadgeClass">
                                                                @(finding.Impact ?? "Unknown impact")
                                                            </span>

                                                            <span class="badge bg-dark">
                                                                @finding.AffectedElementCount
                                                                affected
                                                            </span>
                                                        </div>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(
                                                        finding.Description))
                                                    {
                                                        <p class="small text-muted mt-3 mb-2">
                                                            @finding.Description
                                                        </p>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(
                                                        finding.HelpUrl))
                                                    {
                                                        <a href="@finding.HelpUrl"
                                                           target="_blank"
                                                           rel="noopener noreferrer"
                                                           class="btn btn-sm
                                                            btn-outline-primary">
                                                            View Rule Guidance
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (needsReviewFindings.Count > 0)
                                {
                                    <div>
                                        <h4 class="h6 text-warning">
                                            Needs manual review
                                            (@needsReviewFindings.Count)
                                        </h4>

                                        <div class="d-flex flex-column gap-3">
                                            @foreach (var finding in needsReviewFindings)
                                            {
                                                string impactBadgeClass =
                                                    finding.Impact?.ToLowerInvariant() switch
                                                    {
                                                        "critical" => "bg-danger",
                                                        "serious" => "bg-danger",
                                                        "moderate" => "bg-warning text-dark",
                                                        "minor" => "bg-info text-dark",
                                                        _ => "bg-secondary"
                                                    };

                                                <div class="border border-warning
                                                    rounded
                                                    p-3">
                                                    <div class="d-flex flex-wrap
                                                        justify-content-between
                                                        align-items-start
                                                        gap-2">
                                                        <div>
                                                            <div class="fw-semibold">
                                                                @finding.RuleId
                                                            </div>

                                                            @if (!string.IsNullOrWhiteSpace(
                                                                finding.Help))
                                                            {
                                                                <div>
                                                                    @finding.Help
                                                                </div>
                                                            }
                                                        </div>

                                                        <div class="d-flex flex-wrap gap-2">
                                                            <span class="badge @impactBadgeClass">
                                                                @(finding.Impact ?? "Unknown impact")
                                                            </span>

                                                            <span class="badge bg-dark">
                                                                @finding.AffectedElementCount
                                                                affected
                                                            </span>
                                                        </div>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(
                                                        finding.Description))
                                                    {
                                                        <p class="small text-muted mt-3 mb-2">
                                                            @finding.Description
                                                        </p>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(
                                                        finding.HelpUrl))
                                                    {
                                                        <a href="@finding.HelpUrl"
                                                           target="_blank"
                                                           rel="noopener noreferrer"
                                                           class="btn btn-sm
                                                            btn-outline-primary">
                                                            View Rule Guidance
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(step.ErrorMessage))
                        {
                            <div class="alert alert-danger mt-4 mb-0">
                                <strong>Step error:</strong>
                                @step.ErrorMessage
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
